{
  "name": "memhook",
  "version": "0.1.0-preview.0",
  "description": "Semantic memory router for Claude Code — picks relevant feedbacks & rules per prompt via Haiku, injects them as additionalContext.",
  "type": "module",
  "license": "MIT",
  "author": "wox <hello@utilia-ai.com>",
  "homepage": "https://github.com/utilia-ai-wox/memhook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utilia-ai-wox/memhook.git"
  },
  "bugs": {
    "url": "https://github.com/utilia-ai-wox/memhook/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "memory",
    "hook",
    "userpromptsubmit",
    "semantic-router",
    "haiku"
  ],
  "bin": {
    "memhook": "./dist/bin/memhook.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./hook": {
      "import": "./dist/router.js",
      "types": "./dist/router.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {},
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  }
}
