# Copy to .env (gitignored) and fill in your own values.
# Every variable listed here has a sensible default — set only what you need.

# Provider — Anthropic by default. Multi-provider deferred to v0.2.
ANTHROPIC_API_KEY=sk-ant-api03-…
MEMHOOK_MODEL=claude-haiku-4-5
# MEMHOOK_API_KEY_ENV=ANTHROPIC_API_KEY   # name of the env var memhook reads
# MEMHOOK_BASE_URL=https://api.anthropic.com/v1/messages

# Toggles
# MEMHOOK_ENABLED=true
# MEMHOOK_DISABLE_CACHE=false
# MEMHOOK_DISABLE_PREFILTER=false
# MEMHOOK_DEBUG=false      # set true to print errors to stderr

# Tuning
# MEMHOOK_MAX_FILES=5
# MEMHOOK_MAX_ADDITIONAL_CHARS=9500
# MEMHOOK_MAX_OUTPUT_TOKENS=200
# MEMHOOK_TIMEOUT_MS=8000
# MEMHOOK_CACHE_TTL_MIN=60
# MEMHOOK_CACHE_EVICT_DAYS=7

# Paths (defaults derived from $HOME)
# MEMHOOK_CACHE_DIR=$HOME/.cache/memhook
# MEMHOOK_CATALOG_PATH=$HOME/.claude/cache/memory-catalog.txt
# MEMHOOK_LOG_PATH=$HOME/.claude/logs/memhook.log
# MEMHOOK_TRIVIAL_FILE=$HOME/.config/memhook/trivial-words.txt
