# Lockfiles are not committed: npm's cross-platform optional-dependency bug
# (npm/cli#4828) breaks CI when a single-platform lockfile is committed, so CI
# resolves dev deps fresh per-platform via `npm install`. Zero runtime deps.
package-lock.json
bun.lock

# Private zones — never commit.
# .claude/rules/ is gitignored too: project rules are auto-loaded by Claude
# Code from disk (not git), so keeping them untracked makes them apply locally
# without becoming public artifacts on this open-source repo.
.claude/rules/
.claude/private/
.claude/settings.local.json
docs/private/
